          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is success for create', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "pm.test('Response is JSON when body is present', function () {",
                  "    if (pm.response.text()) {",
                  "        pm.response.to.be.json;",
                  "    }",
                  "});",
                  "",
                  "if (pm.response.text()) {",
                  "    const json = pm.response.json();",
                  "",
                  "    pm.test('Created resource data or identifier is present when evident', function () {",
                  "        const hasIdentifier = json && (",
                  "            json.id !== undefined ||",
                  "            json.userId !== undefined ||",
                  "            json.uuid !== undefined ||",
                  "            json.identifier !== undefined",
                  "        );",
                  "",
                  "        const hasCreatedData = json && (",
                  "            json.username !== undefined ||",
                  "            json.email !== undefined ||",
                  "            json.data !== undefined ||",
                  "            json.user !== undefined",
                  "        );",
                  "",
                  "        pm.expect(hasIdentifier || hasCreatedData).to.equal(true);",
                  "    });",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.variables.set(\"uniqueEmail\", \"victoria_\" + Date.now() + \"@gmail.com\");\r",
                  "pm.variables.set(\"uniqueUsername\", \"victoria_\" + Date.now());"
                ],
