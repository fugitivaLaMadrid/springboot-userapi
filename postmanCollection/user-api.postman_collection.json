        {
          "name": "Search_all_users_sorted_by_username_ascending",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response is JSON when body is present', function () {",
                  "    if (pm.response.text()) {",
                  "        pm.response.to.be.json;",
                  "    }",
                  "});",
                  "",
                  "if (pm.response.text()) {",
                  "    const json = pm.response.json();",
                  "    const users = Array.isArray(json)",
                  "        ? json",
                  "        : Array.isArray(json.users)",
                  "            ? json.users",
                  "            : Array.isArray(json.data)",
                  "                ? json.data",
                  "                : null;",
                  "",
                  "    pm.test('Response contains a user list when provided as list data', function () {",
                  "        pm.expect(users, 'Expected top-level array or users/data array').to.not.equal(null);",
                  "    });",
                  "",
                  "    if (users) {",
                  "        const usernames = users",
                  "            .map(item => item && item.username)",
                  "            .filter(username => typeof username === 'string');",
                  "",
                  "        if (usernames.length > 0) {",
                  "            pm.test('Usernames are sorted ascending', function () {",
                  "                const normalized = usernames.map(name => name.toLowerCase());",
                  "                const sorted = [...normalized].sort((a, b) => a.localeCompare(b));",
                  "                pm.expect(normalized).to.eql(sorted);",
                  "            });",
                  "        }",
                  "    }",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/users/search?name=a&sortBy=username&direction=asc",
              "protocol": "http",
              "host": [
